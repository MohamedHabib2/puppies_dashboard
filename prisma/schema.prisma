generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CityProgress {
  id     Int     @id @default(autoincrement())
  city   String
  status String? @default("working")
  pages  Int?
  date   String?

  @@unique([city, date])
  @@map("cities_table")
}
